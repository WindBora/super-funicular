           RowBox[{"similar", " ", "to", " ", "paper", " ", "near"}], "-", 
           RowBox[{"field", " ", "maps"}]}], ")"}], "--"}], "--"}], "--"}], 
      "--"}], "--"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"xMin", "=", 
     RowBox[{
      RowBox[{"-", "1.2"}], " ", "d"}]}], ";", 
    RowBox[{"xMax", "=", 
     RowBox[{"1.2", " ", "d"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yMinPlot", "=", 
     RowBox[{
      RowBox[{"-", "0.7"}], " ", "d"}]}], ";", 
    RowBox[{"yMaxPlot", "=", 
     RowBox[{"0.7", " ", "d"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"intensityPlot", "=", 
     RowBox[{"DensityPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"UtotAt", "[", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y"}], "}"}], "]"}], "]"}], "^", "2"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xMin", ",", "xMax"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "yMinPlot", ",", "yMaxPlot"}], "}"}], ",", 
       RowBox[{"PlotPoints", "->", "80"}], ",", 
       RowBox[{"MaxRecursion", "->", "1"}], ",", 
       RowBox[{"PlotLegends", "->", "Automatic"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Near-field intensity |U|^2\>\""}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"phasePlot", "=", 
     RowBox[{"DensityPlot", "[", 
      RowBox[{
       RowBox[{"Arg", "[", 
        RowBox[{"UtotAt", "[", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xMin", ",", "xMax"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "yMinPlot", ",", "yMaxPlot"}], "}"}], ",", 
       RowBox[{"PlotPoints", "->", "80"}], ",", 
       RowBox[{"MaxRecursion", "->", "1"}], ",", 
       RowBox[{"PlotLegends", "->", "Automatic"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Near-field phase Arg(U)\>\""}]}], 
      "]"}]}], ";"}]}]}]], "Input",ExpressionUUID->"261e3ea0-71ff-0a41-9307-\
